rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, phone, companyName, bio, createdAt
    //
    // Collection: jobs
    // Fields: id, title, content, location, category, commission, companyName, authorUid, createdAt, updatedAt, views, status
    //
    // Collection: applications
    // Fields: id, jobId, applicantUid, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "noble.kclee@gmail.com" && request.auth.token.email_verified == true));
    }

    function isCompany() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'company';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid is string && data.email is string &&
             data.role in ['agent', 'company'] &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('companyName' in data) || data.companyName is string) &&
             (!('phone' in data) || data.phone is string);
    }

    function isValidJob(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.location is string &&
             data.authorUid == request.auth.uid &&
             data.status in ['open', 'closed'] &&
             (!('companyName' in data) || data.companyName is string) &&
             (!('category' in data) || data.category is string) &&
             (!('commission' in data) || data.commission is string) &&
             (!('views' in data) || data.views is number);
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.authorUid == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isCompany() && isValidJob(request.resource.data);
      allow update: if isDocOwner() && isValidJob(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /applications/{appId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.applicantUid || request.auth.uid == get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.authorUid);
      allow create: if isAuthenticated() && request.resource.data.applicantUid == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.applicantUid || request.auth.uid == get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.authorUid);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.authorUid && isValidPost(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorUid || isAdmin());
    }
  }
}
